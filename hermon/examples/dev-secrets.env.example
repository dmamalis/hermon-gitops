# Copy this file locally and fill in real values.
# Do not commit the filled-in version.

# Namespace
NAMESPACE=hermon-dev

# Timescale admin/bootstrap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Telemetry DB
TELEMETRY_DB_NAME=hermon
TELEMETRY_WRITER_USER=tsdbadmin
TELEMETRY_WRITER_PASSWORD=change-me
TELEMETRY_READER_USER=grafana_ro
TELEMETRY_READER_PASSWORD=change-me

# Grafana application DB
GF_DATABASE_NAME=grafana
GF_DATABASE_USER=grafana
GF_DATABASE_PASSWORD=change-me

# TTN / MQTT
# Replace these with the exact keys expected by the chart / Telegraf config.
TTN_USERNAME=change-me
TTN_PASSWORD=change-me

# GHCR image pull
GHCR_SERVER=ghcr.io
GHCR_USERNAME=change-me
GHCR_PASSWORD=change-me
GHCR_EMAIL=you@example.com
